# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# DO NOT commit actual credentials to git!

# Cloudinary Configuration (Optional - only if you need to upload files)
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
# Note: API Keys and API Secrets should NEVER be exposed in frontend code

# Example for other services (if needed in future)
# VITE_API_URL=https://api.example.com
